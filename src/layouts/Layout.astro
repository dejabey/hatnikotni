---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Hatnikotni Ventures | Independent Digital Studio",
  description = "Building thoughtful, purpose-driven digital products with a focus on simplicity, quality, and long-term value.",
  image = "/og-image.png"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.site);
---

<!doctype html>
<html lang="ms">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook / WhatsApp -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL.href} />
    <meta property="og:image:secure_url" content={socialImageURL.href} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL.href} />
  </head>
  <body>
    <div class="page-wrapper">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  /* Reset Asas CSS */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    background-color: #ffffff;
    color: #111827;
  }

  body {
    min-height: 100vh;
  }

  /* Mengetengahkan kandungan & mengehadkan lebar paparan */
  .page-wrapper {
    max-width: 1080px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  /* Custom text selection style */
  ::selection {
    background-color: #000000;
    color: #ffffff;
  }
</style>